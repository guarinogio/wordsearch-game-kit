{
  "name": "@gioguarino/wordsearch-react",
  "version": "0.1.0",
  "description": "React wrapper for the wordsearch game kit.",
  "license": "MIT",
  "author": "Gio Guarino",
  "homepage": "https://github.com/guarinogio/wordsearch-game-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/guarinogio/wordsearch-game-kit.git",
    "directory": "packages/wordsearch-react"
  },
  "bugs": {
    "url": "https://github.com/guarinogio/wordsearch-game-kit/issues"
  },
  "keywords": [
    "wordsearch",
    "word-search",
    "game",
    "react",
    "pixi"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@gioguarino/wordsearch-pixi": "workspace:*",
    "@gioguarino/wordsearch-types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint src --ext .ts,.tsx"
  }
}
