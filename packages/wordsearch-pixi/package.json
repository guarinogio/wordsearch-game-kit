{
  "name": "@gioguarino/wordsearch-pixi",
  "version": "0.1.0",
  "description": "Pixi renderer/runtime adapter for the wordsearch game kit.",
  "license": "MIT",
  "author": "Gio Guarino",
  "homepage": "https://github.com/guarinogio/wordsearch-game-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/guarinogio/wordsearch-game-kit.git",
    "directory": "packages/wordsearch-pixi"
  },
  "bugs": {
    "url": "https://github.com/guarinogio/wordsearch-game-kit/issues"
  },
  "keywords": [
    "wordsearch",
    "word-search",
    "game",
    "pixi",
    "pixijs",
    "canvas"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@gioguarino/wordsearch-core": "workspace:*",
    "@gioguarino/wordsearch-types": "workspace:*",
    "pixi.js": "^8.17.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint src --ext .ts,.tsx"
  }
}
