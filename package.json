{
  "name": "wordsearch-game-kit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "build:apps": "pnpm --dir apps/demo-web build && pnpm --dir apps/daily-wordsearch-shell build",
    "dev": "pnpm --dir apps/demo-web dev",
    "dev:shell": "pnpm --dir apps/daily-wordsearch-shell dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf node_modules packages/*/dist packages/*/node_modules apps/demo-web/node_modules apps/demo-web/dist apps/daily-wordsearch-shell/node_modules apps/daily-wordsearch-shell/dist",
    "release:check": "pnpm lint && pnpm test && pnpm build && pnpm build:apps",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
