{
  "name": "wordsearch-game-kit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --dir apps/demo-web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf node_modules packages/*/dist packages/*/node_modules apps/demo-web/node_modules apps/demo-web/dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pixi.js": "^8.17.1"
  }
}
