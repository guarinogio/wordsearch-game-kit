{
  "name": "wordsearch-game-kit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --dir apps/demo-web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf node_modules packages/*/dist packages/*/node_modules apps/demo-web/node_modules apps/demo-web/dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  }
}
